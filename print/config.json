{
  "name": "Print",
  "version": "0.1.13",
  "slug": "ha_print",
  "description": "Thermal receipt printing (80mm ESC/POS) for HA-stock and HA-recipes",
  "url": "https://github.com/Glitchtit/HA-print",
  "arch": [
    "aarch64",
    "amd64",
    "armhf",
    "armv7",
    "i386"
  ],
  "startup": "application",
  "boot": "auto",
  "admin": false,
  "panel_admin": false,
  "hassio_api": true,
  "homeassistant_api": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:printer",
  "init": false,
  "ports": {
    "8100/tcp": null
  },
  "ports_description": {
    "8100/tcp": "Internal FastAPI port for sibling add-on access (HA-stock, HA-recipes)"
  },
  "options": {
    "printer_host": "",
    "printer_port": 9100,
    "printer_profile": "default",
    "codepage": "CP858",
    "image_impl": "bitImageRaster",
    "enable_cut": true,
    "column_width": 48,
    "title_style": "a1x2-bold",
    "header_style": "a-bold-underline",
    "item_style": "b",
    "note_style": "b",
    "beep_after_print": false,
    "beep_count": 2,
    "beep_duration_ms": 200,
    "print_density": 5,
    "header_text": "",
    "footer_text": "",
    "full_width_px": 576,
    "svg_default_dither": false,
    "cut_feed_lines": 0,
    "print_scale_v": 1.0,
    "debug": false
  },
  "schema": {
    "printer_host": "str",
    "printer_port": "int(1,65535)",
    "printer_profile": "str?",
    "codepage": "str?",
    "image_impl": "list(bitImageRaster|bitImageColumn)?",
    "enable_cut": "bool?",
    "column_width": "int(16,80)?",
    "title_style": "str?",
    "header_style": "str?",
    "item_style": "str?",
    "note_style": "str?",
    "beep_after_print": "bool?",
    "beep_count": "int(1,9)?",
    "beep_duration_ms": "int(50,1000)?",
    "print_density": "int(0,8)?",
    "header_text": "str?",
    "footer_text": "str?",
    "full_width_px": "int(8,576)?",
    "svg_default_dither": "bool?",
    "cut_feed_lines": "int(0,20)?",
    "print_scale_v": "float(0.5,1.5)?",
    "debug": "bool?"
  }
}
